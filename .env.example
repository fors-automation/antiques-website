# Example environment configuration for Glory Days Past.
# Copy this file to .env and fill in real values. The .env file is gitignored.

# Generate a new key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me

# Set to False in production.
DEBUG=False

# Comma-separated list of allowed hostnames.
ALLOWED_HOSTS=127.0.0.1,localhost

# Database — local PostgreSQL. Falls back to a SQLite file if unset.
DATABASE_URL=postgres://USER:PASSWORD@127.0.0.1:5432/glorydays
